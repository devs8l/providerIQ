# --- Inquantic.Ai / Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Database ---
DATABASE_URL=postgresql://provideriq:provideriq@localhost:5432/provideriq
REDIS_URL=redis://localhost:6379

# --- External APIs — Free / Sandbox ---
ABDM_SANDBOX_BASE_URL=https://dev.abdm.gov.in
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
NABH_BASE_URL=https://www.nabh.co.in

# --- External APIs — Paid ---
GOOGLE_MAPS_API_KEY=
SERPAPI_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
TWITTER_BEARER_TOKEN=
EXA_API_KEY=
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=

# --- App ---
API_PORT=4000
JWT_SECRET=change-me-in-production
NODE_ENV=development
LOG_LEVEL=info

# --- Crawlee (self-hosted scraping) ---
CRAWLEE_MAX_REQUESTS_PER_CRAWL=100
CRAWLEE_REQUEST_HANDLER_TIMEOUT_SECS=60
CRAWLEE_NAVIGATION_TIMEOUT_SECS=45
CRAWLEE_HEADLESS=true
CRAWLEE_STORAGE_DIR=.local/crawlee-storage
CRAWLEE_PROXY_URLS=

# --- Monitoring ---
SENTRY_DSN=

# --- Mapbox (Dashboard) ---
NEXT_PUBLIC_MAPBOX_TOKEN=
